# ===== Storage backend =====
# Local development needs no configuration; notes are stored under data/ by default.
# When deploying to Vercel, set the GitHub variables below to switch to GitHub storage.

# Optional: force a backend (local | github). Leave empty to auto-detect:
#   github when GITHUB_TOKEN + GITHUB_REPO are set or running on Vercel, otherwise local.
# STORAGE_BACKEND=

# ===== GitHub storage (required when deploying to Vercel) =====
# GitHub Personal Access Token (fine-grained, Contents read/write on the storage repo only).
# This is REQUIRED to write to GitHub; the API does not allow anonymous writes.
# GITHUB_TOKEN=github_pat_xxx

# Storage repository, format owner/repo.
# OPTIONAL on Vercel: if omitted, the app stores notes back into the same repo it
# was deployed from, using Vercel's VERCEL_GIT_REPO_OWNER / VERCEL_GIT_REPO_SLUG.
# Set this only to override the target (e.g. a separate private data repo).
# GITHUB_REPO=your-name/your-repo

# Branch name for CODE (deploy). Defaults to the deployed branch
# (VERCEL_GIT_COMMIT_REF), else main. Notes are NOT written here anymore.
# GITHUB_BRANCH=main

# Branch that NOTES are committed to. Defaults to "notes-data".
# This is intentionally SEPARATE from the code/deploy branch so that a
# fork-sync workflow which force-pushes the code branch (main/master) can
# never overwrite your notes. Do NOT include this branch in any fork-sync
# matrix. The app auto-creates it from GITHUB_BRANCH on first write.
# GITHUB_DATA_BRANCH=notes-data

# ===== Shared paths (used by both local and GitHub) =====
# Notes directory (defaults to notes)
# NOTES_DIR=notes

# Attachment directory inside each note folder (defaults to attachment)
# ATTACH_DIR=attachment

# Local data root (local backend only, defaults to data)
# LOCAL_DATA_DIR=data
